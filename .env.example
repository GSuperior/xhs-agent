# SenseNova API (OpenAI兼容, 公测免费)
SENSENOVA_API_KEY=your_sensenova_api_key_here
SENSENOVA_BASE_URL=https://api.sensenova.cn/compatible-mode/v1

# 通用
LOG_LEVEL=INFO
RUNS_DIR=./runs
LOG_DIR=./logs

# 重试预算
MAX_SUPPLEMENT_RESEARCH=2
MAX_SUPPLEMENT_RESEARCH_DEEP=1
MAX_REVISE_OUTLINE=3
MAX_REVISE_COPY=3
MAX_REVISE_LAYOUT=3
MAX_RENDER_RETRY=2

# 成本控制
DAILY_TOKEN_BUDGET=2000000

# 安全
FETCH_ALLOWED_PROTOCOLS=https,http
FETCH_BLOCK_PRIVATE_IP=true
LOG_SENSITIVE_REDACT=true
