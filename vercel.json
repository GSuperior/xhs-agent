{
  "version": 2,
  "builds": [
    {
      "src": "src/xhs_agent/web.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 300,
        "includeFiles": "src/**,config/**,runs/**,tmp_images/**"
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "src/xhs_agent/web.py" }
  ]
}
