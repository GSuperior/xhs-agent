{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "xhs-agent",
  "buildCommand": null,
  "outputDirectory": "src/xhs_agent/web/static",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/showcase.html" },
    { "source": "/showcase", "destination": "/showcase.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
